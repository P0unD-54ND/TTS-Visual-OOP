# [REASONING]: Ignore all Coqui XTTS-v2 neural network weights.
tts_models/

# [REASONING]: Ignore all temporary audio and video artifacts.
*.aac
*.m4a
*.mp4
*.wav

# [REASONING]: Ignore the raw manuscript and logs to keep the repo clean.
sermon_manuscript.txt
*log.txt

# [REASONING]: Ignore Python cache files.
__pycache__/
*.pyc